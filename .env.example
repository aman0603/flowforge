# FlowForge configuration example.
# Copy to `.env` and adjust. Never commit real secrets.
# All values below are safe local/development defaults.

# ---- Core / API ----
PORT=8080
GRPC_ADDR=0.0.0.0:9090
ENV=development
SCHEMA_PATH=schema.sql

# ---- PostgreSQL (durable source of truth) ----
# In production, supply via a secret manager, not a committed file.
# docker-compose reads POSTGRES_* to provision the db container.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=flowforge
DB_URL=postgres://postgres:postgres@localhost:5432/flowforge?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# ---- Redis (ephemeral coordination) ----
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Worker heartbeats / leases ----
WORKER_HEARTBEAT_INTERVAL_MS=1000
WORKER_HEARTBEAT_TTL_MS=3000
TASK_LEASE_TTL_MS=5000
TASK_LEASE_RENEW_INTERVAL_MS=1500

# ---- Worker pool ----
WORKER_POLL_INTERVAL=1s
WORKER_POOL_SIZE=16
WORKER_QUEUE_CAPACITY=32
WORKER_CLAIM_BATCH_SIZE=8
WORKER_SHUTDOWN_GRACE_PERIOD_MS=10000

# ---- Recovery / stale-task reclamation ----
CLAIMED_STALE_TIMEOUT=30s
RUNNING_STALE_TIMEOUT=5m
RECOVERY_INTERVAL=30s

# ---- Kafka (async events) ----
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=flowforge.workflow-events.v1
KAFKA_CLIENT_ID=flowforge-app

# ---- Transactional outbox publisher ----
OUTBOX_POLL_INTERVAL=500ms
OUTBOX_BATCH_SIZE=100
OUTBOX_CLAIM_TIMEOUT=30s
OUTBOX_MAX_RETRIES=5
OUTBOX_RETRY_BASE_DELAY=1s
OUTBOX_RETENTION=24h

# ---- Internal gRPC service addresses ----
SCHEDULER_ADDR=
RECOVERY_ADDR=
GRPC_RETRY_MAX_ATTEMPTS=3
GRPC_RETRY_BASE_DELAY=50ms
GRPC_REQUEST_TIMEOUT=5s

# ---- gRPC transport security (opt-in) ----
# When GRPC_TLS_ENABLED=true, servers require the cert/key and clients verify
# against the CA. Supplying a CA on the server enables mutual TLS.
GRPC_TLS_ENABLED=false
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_CA_FILE=

# ---- HTTP DoS protection ----
# RATE_LIMIT_RPS=0 disables the limiter (default). Burst defaults to RPS.
RATE_LIMIT_RPS=0
RATE_LIMIT_BURST=0
# Max JSON request body accepted on write endpoints (bytes, default 1 MiB).
MAX_REQUEST_BODY_BYTES=1048576

# ---- Observability ----
METRICS_ADDR=:9091
# Expose net/http/pprof on the metrics server under /debug/pprof/. Keep false
# outside controlled environments.
PPROF_ENABLED=false
LOG_LEVEL=info
OTEL_DISABLED=true
OTEL_SERVICE_NAME=flowforge
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
